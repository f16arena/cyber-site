// Esports.kz database schema
// Подробнее: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Game {
  CS2
  DOTA2
  PUBG
}

enum Region {
  ALMATY
  ASTANA
  SHYMKENT
  KARAGANDA
  AKTAU
  AKTOBE
  PAVLODAR
  ATYRAU
  ORAL
  KOSTANAY
  TARAZ
  KZ_OTHER
}

enum PlayerStatus {
  ONLINE
  LOOKING_FOR_TEAM
  IN_MATCH
  OFFLINE
}

enum TeamMemberRole {
  CAPTAIN
  PLAYER
  SUBSTITUTE
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  COMPLETED
  CANCELLED
}

enum TournamentFormat {
  DOUBLE_ELIMINATION
  SINGLE_ELIMINATION
  ROUND_ROBIN
  BATTLE_ROYALE_SERIES
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
  WALKOVER
}

enum SponsorTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum NewsCategory {
  TOURNAMENT
  MVP
  SPONSOR
  TEAM
  GENERAL
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  TEAM_INVITE
  TEAM_JOIN_REQUEST
  TEAM_REQUEST_ACCEPTED
  TEAM_REQUEST_DECLINED
  TEAM_KICKED
  MATCH_REMINDER
  MATCH_RESULT
  MVP_AWARDED
  TOURNAMENT_REGISTERED
  NEW_MESSAGE
  SPONSOR_INQUIRY
  SYSTEM
}

enum TeamPrivacy {
  PUBLIC
  PRIVATE
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MessagePrivacy {
  EVERYONE
  FRIENDS_ONLY
}

// ─── USER ────────────────────────────────────────────────

model User {
  id          String        @id @default(cuid())
  steamId     String        @unique
  username    String        @unique
  avatarUrl   String?
  email       String?       @unique
  bio         String?
  region      Region?
  twitchUrl   String?
  discordTag  String?
  status         PlayerStatus    @default(OFFLINE)
  isAdmin        Boolean         @default(false)
  messagePrivacy MessagePrivacy  @default(EVERYONE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lastSeenAt     DateTime?

  profiles        PlayerProfile[]
  teamMemberships TeamMember[]
  captainOf       Team[]            @relation("TeamCaptain")
  lfgPosts        LfgPost[]
  sentMessages    ChatMessage[]     @relation("MessageSender")
  friendsSent     Friendship[]      @relation("FriendshipFrom")
  friendsRecv     Friendship[]      @relation("FriendshipTo")
  mvpAwards       MvpAward[]
  authoredNews    News[]            @relation("NewsAuthor")
  notifications   Notification[]    @relation("NotificationRecipient")
  joinRequests    TeamJoinRequest[]

  @@index([status])
  @@index([region])
}

model PlayerProfile {
  id          String   @id @default(cuid())
  userId      String
  game        Game
  inGameRole  String?
  rank        String?
  hoursPlayed Int?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, game])
  @@index([game])
}

// ─── TEAMS ───────────────────────────────────────────────

model Team {
  id          String      @id @default(cuid())
  name        String
  tag         String      @unique
  logoUrl     String?
  game        Game
  region      Region?
  captainId   String
  description String?
  rating      Int         @default(1000)
  privacy     TeamPrivacy @default(PUBLIC)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  captain       User                     @relation("TeamCaptain", fields: [captainId], references: [id])
  members       TeamMember[]
  matchesA      Match[]                  @relation("MatchTeamA")
  matchesB      Match[]                  @relation("MatchTeamB")
  wonMatches    Match[]                  @relation("MatchWinner")
  registrations TournamentRegistration[]
  joinRequests  TeamJoinRequest[]

  @@unique([name, game])
  @@index([game])
  @@index([rating])
}

model TeamJoinRequest {
  id        String            @id @default(cuid())
  teamId    String
  userId    String
  status    JoinRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime          @default(now())
  decidedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId, status])
}

model TeamMember {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(PLAYER)
  joinedAt  DateTime       @default(now())

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

// ─── LFG ─────────────────────────────────────────────────

model LfgPost {
  id          String    @id @default(cuid())
  authorId    String
  game        Game
  description String
  inGameRole  String?
  region      Region?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([game, isActive])
  @@index([region])
}

// ─── TOURNAMENTS ─────────────────────────────────────────

model Tournament {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  game          Game
  format        TournamentFormat
  status        TournamentStatus @default(DRAFT)
  prize         BigInt           @default(0)
  prizeCurrency String           @default("KZT")
  maxTeams      Int              @default(16)
  description   String?
  rules         String?
  bannerUrl     String?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  registrations TournamentRegistration[]
  matches       Match[]
  mvpAwards     MvpAward[]
  sponsors      TournamentSponsor[]

  @@index([game, status])
  @@index([startsAt])
}

model TournamentRegistration {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  approvedAt   DateTime?
  createdAt    DateTime   @default(now())

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
}

// ─── MATCHES ─────────────────────────────────────────────

enum BracketSide {
  UPPER  // UB (winners bracket)
  LOWER  // LB (losers bracket)
  GROUP  // group stage
}

model Match {
  id             String      @id @default(cuid())
  tournamentId   String?
  teamAId        String?     // nullable, пока не определена в жеребьёвке
  teamBId        String?
  winnerId       String?
  status         MatchStatus @default(SCHEDULED)
  scoreA         Int         @default(0)
  scoreB         Int         @default(0)
  bestOf         Int         @default(1)
  stage          String?
  round          Int?        // 1, 2, 3... для round-robin / brackets
  bracketSide    BracketSide?
  bracketPosition Int?       // позиция в сетке (порядок отрисовки)
  parentMatchAId String?     // из какого матча пришла команда A
  parentMatchBId String?
  map            String?
  twitchChannel  String?
  startsAt       DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  resultProofUrl String?
  createdAt      DateTime    @default(now())

  tournament     Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  teamA          Team?        @relation("MatchTeamA", fields: [teamAId], references: [id])
  teamB          Team?        @relation("MatchTeamB", fields: [teamBId], references: [id])
  winner         Team?        @relation("MatchWinner", fields: [winnerId], references: [id])
  parentMatchA   Match?       @relation("ParentMatchA", fields: [parentMatchAId], references: [id], onDelete: SetNull)
  parentMatchB   Match?       @relation("ParentMatchB", fields: [parentMatchBId], references: [id], onDelete: SetNull)
  childrenA      Match[]      @relation("ParentMatchA")
  childrenB      Match[]      @relation("ParentMatchB")
  mvp            MvpAward?
  playerStats    MatchPlayerStat[]

  @@index([status])
  @@index([startsAt])
  @@index([tournamentId, round])
  @@index([tournamentId, bracketSide, bracketPosition])
}

// Статистика игрока в конкретном матче (HLTV-style)
model MatchPlayerStat {
  id              String   @id @default(cuid())
  matchId         String
  userId          String
  teamId          String

  // Базовые показатели (общие для всех игр)
  kills           Int      @default(0)
  deaths          Int      @default(0)
  assists         Int      @default(0)
  mvpRounds       Int      @default(0)
  rating          Float?   // HLTV-style Rating 2.0 — рассчитывается из других метрик

  // Специфика игры — JSON, чтобы не плодить колонки
  // CS2: { adr, hsPct, kast, openingKills, clutches1v1, clutches1v2, utilityDamage, flashAssists }
  // DOTA2: { gpm, xpm, lastHits, denies, heroDamage, towerDamage, healing, hero }
  // PUBG: { headshotKills, longestKill, damageDealt, distanceTraveled, placement }
  extra           Json?

  // Метаданные
  game            Game
  isMvp           Boolean  @default(false)
  recordedById    String?  // админ, который ввёл стату
  recordedAt      DateTime @default(now())

  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId, game])
  @@index([userId, recordedAt])
}

// Сезоны — для группировки турниров и долгосрочных лидербордов
model Season {
  id          String   @id @default(cuid())
  name        String   // "Spring 2026", "Summer 2026"
  slug        String   @unique
  game        Game?    // null = все игры
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  @@index([game, isActive])
}

// ─── MVP & AWARDS ────────────────────────────────────────

model MvpAward {
  id           String      @id @default(cuid())
  userId       String
  tournamentId String?
  matchId      String?     @unique
  comment      String?
  createdAt    DateTime    @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  match        Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
}

// ─── CHAT & FRIENDSHIPS ──────────────────────────────────

model Conversation {
  id        String        @id @default(cuid())
  isGroup   Boolean       @default(false)
  name      String?
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Friendship {
  id        String           @id @default(cuid())
  fromId    String
  toId      String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  from      User             @relation("FriendshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        User             @relation("FriendshipTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([toId, status])
}

// ─── SPONSORS ────────────────────────────────────────────

model Sponsor {
  id            String      @id @default(cuid())
  name          String
  logoUrl       String?
  websiteUrl    String?
  tier          SponsorTier
  isActive      Boolean     @default(true)
  contractStart DateTime?
  contractEnd   DateTime?
  monthlyFeeKzt Int?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tournamentLinks TournamentSponsor[]

  @@index([tier, isActive])
}

model TournamentSponsor {
  id           String     @id @default(cuid())
  tournamentId String
  sponsorId    String
  isTitle      Boolean    @default(false)
  createdAt    DateTime   @default(now())

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  sponsor      Sponsor    @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, sponsorId])
}

model SponsorshipInquiry {
  id          String       @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  tier        SponsorTier?
  message     String?
  createdAt   DateTime     @default(now())
  isHandled   Boolean      @default(false)

  @@index([isHandled, createdAt])
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String           // получатель
  type       NotificationType
  title      String
  body       String?
  link       String?          // куда вести при клике (например /matches/abc)
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user       User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── NEWS ────────────────────────────────────────────────

model News {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String?
  body        String
  category    NewsCategory @default(GENERAL)
  game        Game?
  coverUrl    String?
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author      User?        @relation("NewsAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([category, publishedAt])
  @@index([game, publishedAt])
}
